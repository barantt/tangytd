---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import en from '../i18n/en.json';
import zh from '../i18n/zh.json';

const lang = Astro.currentLocale || 'en';
const t = lang === 'zh' ? zh : en;

const skillTrees = [
  {
    id: 'defender',
    name: t.skillTree.defenderTree.name,
    description: t.skillTree.defenderTree.description,
    color: 'from-blue-500 to-cyan-500',
    bgColor: 'bg-blue-500/10',
    borderColor: 'border-blue-500/30',
    branches: t.skillTree.defenderTree.branches,
  },
  {
    id: 'archer',
    name: t.skillTree.archerTree.name,
    description: t.skillTree.archerTree.description,
    color: 'from-green-500 to-emerald-500',
    bgColor: 'bg-green-500/10',
    borderColor: 'border-green-500/30',
    branches: t.skillTree.archerTree.branches,
  },
  {
    id: 'healer',
    name: t.skillTree.healerTree.name,
    description: t.skillTree.healerTree.description,
    color: 'from-yellow-500 to-orange-500',
    bgColor: 'bg-yellow-500/10',
    borderColor: 'border-yellow-500/30',
    branches: t.skillTree.healerTree.branches,
  },
];

const tips = t.skillTree.tips.list;
---

<Layout 
  title={`${t.skillTree.title} | ${t.site.title}`}
  description={t.skillTree.subtitle}
>
  <Navigation t={t} lang={lang} />
  
  <main class="pt-16">
    <section class="py-24 bg-slate-950 relative overflow-hidden">
      <!-- Background -->
      <div class="absolute inset-0 bg-cover bg-center opacity-20" style="background-image: url(/skill-tree-bg.jpg)"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-slate-950 via-transparent to-slate-950"></div>

      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Section Header -->
        <div class="text-center mb-16">
          <h1 class="text-4xl sm:text-5xl font-bold mb-4">
            <span class="bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent">{t.skillTree.title}</span>
          </h1>
          <p class="text-slate-400 text-lg max-w-2xl mx-auto">{t.skillTree.subtitle}</p>
        </div>

        <!-- Skill Trees -->
        <div class="space-y-16">
          {skillTrees.map((tree) => (
            <div class={`p-8 rounded-2xl ${tree.bgColor} border-2 ${tree.borderColor} backdrop-blur-sm`}>
              <div class="flex items-center gap-4 mb-8">
                <div class={`w-14 h-14 rounded-xl bg-gradient-to-br ${tree.color} flex items-center justify-center`}>
                  <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11.5V14m0-2.5v-6a1.5 1.5 0 113 0m-3 6a1.5 1.5 0 00-3 0v2a7.5 7.5 0 0015 0v-5a1.5 1.5 0 00-3 0m-6-3V11m0-5.5v-1a1.5 1.5 0 013 0v1m0 0V11m0-5.5a1.5 1.5 0 013 0v3m0 0V11"></path>
                  </svg>
                </div>
                <div>
                  <h2 class="text-2xl font-bold text-white">{tree.name}</h2>
                  <p class="text-slate-400">{tree.description}</p>
                </div>
              </div>

              <!-- Branches -->
              <div class="grid md:grid-cols-3 gap-6">
                {tree.branches.map((branch) => (
                  <div class="p-6 rounded-xl bg-slate-900/50 border border-white/10 hover:border-white/20 transition-colors">
                    <h3 class={`text-lg font-bold bg-gradient-to-r ${tree.color} bg-clip-text text-transparent mb-2`}>
                      {branch.name}
                    </h3>
                    <p class="text-sm text-slate-400 mb-4">{branch.description}</p>
                    
                    <div class="space-y-3">
                      {branch.nodes.map((node) => (
                        <div class="flex items-start gap-3 p-3 rounded-lg bg-slate-800/50">
                          <svg class={`w-4 h-4 mt-0.5 flex-shrink-0 ${tree.id === 'defender' ? 'text-blue-400' : tree.id === 'archer' ? 'text-green-400' : 'text-yellow-400'}`} fill="currentColor" viewBox="0 0 20 20">
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                          </svg>
                          <div>
                            <div class="font-medium text-slate-200 text-sm">{node.name}</div>
                            <div class="text-xs text-slate-500">{node.effect}</div>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>

        <!-- Tips -->
        <div class="mt-12 p-6 rounded-xl bg-slate-900/50 border border-purple-500/30">
          <div class="flex items-center gap-2 mb-4">
            <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <h3 class="font-semibold text-slate-200">{t.skillTree.tips.title}</h3>
          </div>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {tips.map((tip) => (
              <div class="flex items-start gap-2">
                <svg class="w-4 h-4 text-purple-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
                <span class="text-sm text-slate-400">{tip}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer t={t} />
</Layout>
