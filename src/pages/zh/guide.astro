---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import zh from '../../i18n/zh.json';

const t = zh;

const steps = t.guide.steps;
const faqs = t.guide.faq.list;
const tips = t.guide.tips.list;
---

<Layout 
  title={`${t.guide.title} | ${t.site.title}`}
  description={t.guide.subtitle}
>
  <Navigation t={t} lang="zh" />
  
  <main class="pt-16">
    <section class="py-24 bg-slate-950">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Section Header -->
        <div class="text-center mb-16">
          <h1 class="text-4xl sm:text-5xl font-bold mb-4">
            <span class="bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent">{t.guide.title}</span>
          </h1>
          <p class="text-slate-400 text-lg max-w-2xl mx-auto">{t.guide.subtitle}</p>
        </div>

        <!-- Steps -->
        <div class="mb-16">
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {steps.map((step, index) => (
              <div class="p-6 rounded-2xl bg-slate-900/50 border border-white/10 hover:border-purple-500/30 transition-colors">
                <div class="flex items-center gap-3 mb-4">
                  <div class={`w-10 h-10 rounded-lg flex items-center justify-center ${index === 0 ? 'bg-blue-500/20 text-blue-400' : index === 1 ? 'bg-green-500/20 text-green-400' : index === 2 ? 'bg-yellow-500/20 text-yellow-400' : index === 3 ? 'bg-purple-500/20 text-purple-400' : 'bg-red-500/20 text-red-400'}`}>
                    <span class="font-bold">{index + 1}</span>
                  </div>
                  <h3 class="text-lg font-bold text-white">{step.title}</h3>
                </div>
                <ul class="space-y-2">
                  {step.content.map((item) => (
                    <li class="flex items-start gap-2 text-sm text-slate-400">
                      <svg class="w-4 h-4 text-purple-400 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                      </svg>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>

        <!-- FAQ & Tips -->
        <div class="grid lg:grid-cols-2 gap-8">
          <!-- FAQ -->
          <div>
            <h2 class="text-2xl font-bold text-slate-200 mb-6 flex items-center gap-2">
              <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              {t.guide.faq.title}
            </h2>
            <div class="space-y-4">
              {faqs.map((faq) => (
                <details class="group border border-slate-700 rounded-xl overflow-hidden">
                  <summary class="flex items-center justify-between p-4 cursor-pointer hover:bg-slate-900/50 transition-colors">
                    <span class="font-medium text-slate-200">{faq.q}</span>
                    <svg class="w-5 h-5 text-slate-400 group-open:rotate-90 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                  </summary>
                  <div class="px-4 pb-4">
                    <p class="text-slate-400 text-sm">{faq.a}</p>
                  </div>
                </details>
              ))}
            </div>
          </div>

          <!-- Tips -->
          <div>
            <h2 class="text-2xl font-bold text-slate-200 mb-6 flex items-center gap-2">
              <svg class="w-6 h-6 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M11 3a1 1 0 10-2 0v1a1 1 0 102 0V3zM15.657 5.757a1 1 0 00-1.414-1.414l-.707.707a1 1 0 001.414 1.414l.707-.707zM18 10a1 1 0 01-1 1h-1a1 1 0 110-2h1a1 1 0 011 1zM5.05 6.464A1 1 0 106.464 5.05l-.707-.707a1 1 0 00-1.414 1.414l.707.707zM5 10a1 1 0 01-1 1H3a1 1 0 110-2h1a1 1 0 011 1zM8 16v-1h4v1a2 2 0 11-4 0zM12 14c.015-.34.208-.646.477-.859a4 4 0 10-4.954 0c.27.213.462.519.476.859h4.002z"></path>
              </svg>
              {t.guide.tips.title}
            </h2>
            <div class="p-6 rounded-xl bg-yellow-500/10 border border-yellow-500/30">
              <div class="space-y-4">
                {tips.map((tip, index) => (
                  <div class="flex items-start gap-3">
                    <div class="w-6 h-6 rounded-full bg-yellow-500/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                      <span class="text-xs text-yellow-400 font-medium">{index + 1}</span>
                    </div>
                    <span class="text-slate-300">{tip}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer t={t} />
</Layout>
