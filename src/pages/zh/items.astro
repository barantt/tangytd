---
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import zh from '../../i18n/zh.json';

const t = zh;

const rareItems = t.items.rare.list;
const recipes = t.items.recipes;
---

<Layout 
  title={`${t.items.title} | ${t.site.title}`}
  description={t.items.subtitle}
>
  <Navigation t={t} lang="zh" />
  
  <main class="pt-16">
    <section class="py-24 bg-slate-950 relative overflow-hidden">
      <!-- Background -->
      <div class="absolute inset-0 bg-cover bg-center opacity-15" style="background-image: url(/items-crafting.jpg)"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-slate-950 via-transparent to-slate-950"></div>

      <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Section Header -->
        <div class="text-center mb-16">
          <h1 class="text-4xl sm:text-5xl font-bold mb-4">
            <span class="bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent">{t.items.title}</span>
          </h1>
          <p class="text-slate-400 text-lg max-w-2xl mx-auto">{t.items.subtitle}</p>
        </div>

        <!-- Recipes Grid -->
        <div class="mb-16">
          <h2 class="text-2xl font-bold text-slate-200 mb-8 flex items-center gap-2">
            <svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>
            </svg>
            {t.items.combos.title}
          </h2>
          
          <div class="grid md:grid-cols-2 gap-6">
            {recipes.map((recipe) => (
              <div class="p-6 rounded-2xl bg-slate-900/50 border-2 border-purple-500/30 backdrop-blur-sm">
                <div class={`p-4 rounded-xl bg-gradient-to-r ${recipe.name === '烈焰之刃' ? 'from-red-500 to-orange-500' : recipe.name === '生命护符' ? 'from-green-500 to-emerald-500' : recipe.name === '雷霆战甲' ? 'from-blue-500 to-purple-500' : 'from-yellow-500 to-orange-500'} bg-opacity-10 border border-white/20 mb-4`}>
                  <div class="flex items-center justify-between mb-2">
                    <h3 class="text-xl font-bold text-white">{recipe.result.name}</h3>
                    <span class={`px-3 py-1 rounded-full text-xs font-medium ${recipe.result.rarity === '传说' ? 'bg-yellow-500/20 text-yellow-300' : recipe.result.rarity === '史诗' ? 'bg-purple-500/20 text-purple-300' : 'bg-blue-500/20 text-blue-300'}`}>
                      {recipe.result.rarity}
                    </span>
                  </div>
                  <p class="text-sm text-slate-400 mb-3">{recipe.desc}</p>
                  <div class="space-y-1">
                    {recipe.result.stats.map((stat) => (
                      <div class="flex items-center gap-2 text-sm text-white/80">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                        </svg>
                        {stat}
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Rare Items -->
        <div>
          <h2 class="text-2xl font-bold text-slate-200 mb-8 flex items-center gap-2">
            <svg class="w-6 h-6 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
            {t.items.rare.title}
          </h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
            {rareItems.map((item) => (
              <div class={`p-4 rounded-xl ${item.rarity === '传说' ? 'bg-yellow-500/10 border-yellow-500/30' : item.rarity === '史诗' ? 'bg-purple-500/10 border-purple-500/30' : 'bg-blue-500/10 border-blue-500/30'} border hover:scale-105 transition-transform`}>
                <div class={`font-semibold ${item.rarity === '传说' ? 'text-yellow-400' : item.rarity === '史诗' ? 'text-purple-400' : 'text-blue-400'} mb-1`}>{item.name}</div>
                <div class="text-xs text-slate-500 mb-2">{item.rarity}</div>
                <div class="text-sm text-slate-400">{item.desc}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer t={t} />
</Layout>
